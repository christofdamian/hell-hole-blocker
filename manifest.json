{
  "manifest_version": 3,
  "name": "Twitter Hellhole",
  "version": "1.0",
  "description": "Replaces all Twitter/X links and embeds with a hell hole themed placeholder.",
  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["style.css"],
      "js": ["content.js"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "hellhole-blocker@christofdamian.github.io",
      "data_collection_permissions": {
        "required": ["none"]
      },
      "privacy_policy": "https://github.com/christofdamian/hell-hole-blocker/blob/main/README.md"
    }
  }
}